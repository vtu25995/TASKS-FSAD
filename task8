import org.springframework.beans.factory.BeanFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.context.annotation.*;
import org.springframework.stereotype.Component;
import org.springframework.context.annotation.AnnotationConfigApplicationContext;
import java.util.*;

@Component
class EmployeeRepository {
    private List<String> employees = new ArrayList<>();

    public void addEmployee(String name) {
        employees.add(name);
    }

    public List<String> getEmployees() {
        return employees;
    }
}

@Component
class EmployeeService {

    @Autowired
    private EmployeeRepository repository;

    public void createEmployee(String name) {
        repository.addEmployee(name);
    }

    public void displayEmployees() {
        repository.getEmployees().forEach(System.out::println);
    }
}

@Configuration
@ComponentScan
class AppConfig {}

public class Task8_EmployeeSpringCore {
    public static void main(String[] args) {

        BeanFactory factory = new AnnotationConfigApplicationContext(AppConfig.class);

        EmployeeService service = factory.getBean(EmployeeService.class);

        service.createEmployee("John");
        service.createEmployee("David");
        service.createEmployee("Vijay");

        service.displayEmployees();
    }
}
